# ─── Site ─────────────────────────────────────────────────────────────────
# Canonical origin used by metadata (OG/Twitter URLs, robots, sitemap).
# Local dev: http://localhost:3000   Production: https://thehifzproject.com
NEXT_PUBLIC_SITE_URL=https://thehifzproject.com

# ─── Supabase ─────────────────────────────────────────────────────────────
# From Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, bypasses RLS (used by webhook + admin tasks)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Groq (Whisper transcription) ─────────────────────────────────────────
# From console.groq.com → API Keys
GROQ_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────
# Use TEST keys (sk_test_...) in local dev, LIVE keys in prod.
# We don't use Stripe.js in the browser — checkout is server-side redirect-only —
# so no NEXT_PUBLIC_ publishable key is needed.
STRIPE_SECRET_KEY=

# Recurring price for "The Hifz Project — Voice" ($5/mo)
# Live: price_1TLxbj2O9CSgP6yN2Az9pcxw
# Test: (create a test-mode price and paste its ID here for local dev)
STRIPE_PRICE_VOICE=

# Webhook signing secret
# Local dev: from `stripe listen --forward-to localhost:3000/api/stripe/webhook` (starts with whsec_)
# Production: from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
